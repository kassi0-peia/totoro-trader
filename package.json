{
  "name": "totoro-trader",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/ibkr-server.js",
    "start": "concurrently -k -n SERVER,WEB -c cyan,magenta \"npm:server\" \"npm:dev\"",
    "serve": "vite build && node server/ibkr-server.js",
    "serve:https": "vite build && cross-env TLS=1 IBKR_MD_TYPE=1 node server/ibkr-server.js",
    "test": "node --test src/*.test.js server/*.test.js"
  },
  "dependencies": {
    "@stoqey/ib": "^1.3.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^10.1.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
